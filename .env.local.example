# Spotify API Credentials
# Ersetze die Werte mit deinen echten Credentials von https://developer.spotify.com/dashboard
# WICHTIG: Füge deine echten Keys NIEMALS zu Git hinzu!

VITE_SPOTIFY_CLIENT_ID=your_client_id_here
VITE_SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Redirect nach Spotify-Login – muss EXAKT so im Spotify Developer Dashboard eingetragen sein.
# Für lokale Entwicklung (npm run dev):
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173/Hitzkopf
# Für Production diese Zeile stattdessen verwenden (oder weglassen – wird automatisch genutzt):
# VITE_SPOTIFY_REDIRECT_URI=https://nkillich.github.io/Hitzkopf
